# Backend Configuration

# Database
DATABASE_URL=sqlite+aiosqlite:////app/data/conferente.db

# Debug mode
DEBUG=false

# App info
APP_NAME=Conferente - Contador de Perfis
APP_VERSION=1.0.0

# CORS Origins (separados por vírgula)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Default detection parameters
DEFAULT_MIN_RADIUS=8
DEFAULT_MAX_RADIUS=80
DEFAULT_CANNY_LOW=30
DEFAULT_CANNY_HIGH=100
DEFAULT_HOUGH_PARAM1=50
DEFAULT_HOUGH_PARAM2=25
DEFAULT_MIN_DIST=20
